\\ A coefficients: [6 (n - 1) (2 n - 3) (7 n - 2), 329 n  - 752 n  + 491 n - 84, 
\\                                                    - 2 n (2 n - 1) (7 n - 9)] 
\\ 2*n*(2*n-1)*(7*n-9)*a(n) = (329*n^3 - 752*n^2 + 491*n - 84)*a(n-1) + 6*(n-1)*(2*n-3)*(7*n-2)*a(n-2) 
a(n) = {my(v=[1,4]); 
  if(n<2, v[n+1],
    ((329*n^3 - 752*n^2 + 491*n - 84)*a(n-1) + 6*(n-1)*(2*n-3)*(7*n-2)*a(n-2))
    /(2*n*(2*n-1)*(7*n-9))
  )
};
for(n=0, 19, print1(a(n),", "));
